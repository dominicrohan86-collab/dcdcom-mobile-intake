{
  "name": "dcdcom-mobile-intake",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "drizzle-kit generate --config infra/database/drizzle.config.js",
    "db:check": "drizzle-kit check --config infra/database/drizzle.config.js",
    "build": "node scripts/build/build.mjs",
    "deploy": "wrangler deploy --config infra/cloudflare/wrangler.jsonc",
    "dev": "node --no-warnings scripts/dev/dev-server.mjs",
    "accessibility:check": "node --no-warnings tests/ui/accessibility-check.mjs",
    "performance:budget": "node --no-warnings scripts/release/performance-budget.mjs",
    "test:api": "node --no-warnings tests/api/api.test.mjs",
    "test:mobile-ui": "node --no-warnings tests/ui/mobile-ui.test.mjs",
    "test:pwa": "node --no-warnings tests/pwa/pwa.test.mjs",
    "readiness": "node --no-warnings scripts/release/readiness.mjs",
    "release:check": "node --no-warnings scripts/release/release-check.mjs",
    "verify": "node scripts/release/verify.mjs && node --no-warnings tests/api/api.test.mjs && node --no-warnings tests/ui/mobile-ui.test.mjs && node --no-warnings tests/pwa/pwa.test.mjs && node --no-warnings tests/ui/accessibility-check.mjs && node --no-warnings scripts/release/readiness.mjs && node --no-warnings scripts/release/release-check.mjs && npm run build && node --no-warnings scripts/release/performance-budget.mjs"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.26",
    "ky": "^2.0.2",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.80.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.3.2",
    "vite": "^8.0.16",
    "wrangler": "^4.109.0"
  }
}
